# DV Creative Director — Variables de entorno

# Ruta al directorio de brand systems (compartido con dv_design_agent)
# Por defecto busca en ../dv_design_agent/brands/
# Cambiar si la estructura de directorios es distinta
DV_BRANDS_DIR=../dv_design_agent/brands

# Ruta al directorio de outputs
# Por defecto usa ./outputs/
DV_OUTPUTS_DIR=./outputs

# Nombre del agente de diseño (para referencias en los briefs)
DV_DESIGN_AGENT_DIR=../dv_design_agent
