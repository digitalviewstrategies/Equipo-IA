# Meta Ads API credentials
# Copia este archivo a .env y completa los valores reales.
# Nunca commitees .env (esta en .gitignore).

# Token de acceso generado desde Meta Business Manager > System Users > Generate Token.
# Permisos necesarios: ads_management, ads_read, business_management.
META_ACCESS_TOKEN=tu_token_aqui

# App ID y Secret de la app de Meta for Developers asociada al Business Manager.
META_APP_ID=XXXXXXXXX
META_APP_SECRET=XXXXXXXXX

# Business Portfolio ID (contenedor de todas las ad accounts de clientes).
# Lo ves en Business Manager > Business Settings > Business Info.
META_BUSINESS_ID=XXXXXXXXX

# El ad_account_id NO va aqui. Se configura por cliente en
# shared/brands/[cliente].json bajo meta_ads.ad_account_id.
