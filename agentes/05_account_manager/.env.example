# Meta WhatsApp Cloud API
WABA_TOKEN=EAAG...                  # System User token, permisos whatsapp_business_messaging + whatsapp_business_management
PHONE_NUMBER_ID=123456789012345     # ID del numero "DV Asistente" en Cloud API
WABA_ID=987654321098765             # WhatsApp Business Account ID
VERIFY_TOKEN=algo_secreto_aqui      # token que vos elegis y configuras en el webhook de Meta
APP_SECRET=xxxxxxxxxxxx             # App Secret para validar firma X-Hub-Signature-256

# Canal de aprobacion
FELIPE_WA_NUMBER=+5491155551234     # numero E.164 al que se mandan borradores

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
INTENT_MODEL=claude-haiku-4-5-20251001
DRAFT_MODEL=claude-sonnet-4-6

# Reuso de 04_pauta para handler de performance
META_ACCESS_TOKEN=                  # mismo token que 04_pauta/.env si es el mismo system user
