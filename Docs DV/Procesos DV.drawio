        <mxCell id="WQevSi59tPaS4Q5A-O26-27" parent="1" style="whiteSpace=wrap;html=1;rounded=0;align=left;" value="&lt;ul&gt;&lt;li&gt;Gian&lt;/li&gt;&lt;li&gt;Fran&lt;/li&gt;&lt;li&gt;Eze&lt;/li&gt;&lt;li&gt;Bauti&lt;/li&gt;&lt;/ul&gt;" vertex="1">
