        <mxCell id="RNiMkzj5-1wqcpnOhJM3-3" parent="1" style="whiteSpace=wrap;html=1;rounded=0;fontStyle=1" value="PM &lt;span style=&quot;font-weight: normal;&quot;&gt;crea grupo/drive/accesos/OB/ficha interna/etc&lt;/span&gt;" vertex="1">
